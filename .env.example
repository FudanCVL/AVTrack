# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# --- Dataset root ---
# Directory containing avtract_meta.json, Images/, Audios/, Instance_Masks/,
# Instance_Masks_merged/. Used by configs/data/avtrack.yaml.
AVTRACK_DATA_ROOT=./data

# --- Model paths (optional) ---
# If unset, configs default to HuggingFace repo ids and weights are downloaded
# automatically on first use. Set these to local paths for offline use.
QWEN3VL_4B_PATH=/path/to/Qwen3-VL-4B-Instruct
QWEN3VL_8B_PATH=/path/to/Qwen3-VL-8B-Instruct
SAM3_PATH=/path/to/sam3
WHISPER_LARGE_PATH=/path/to/whisper-large-v3-turbo
WHISPER_SMALL_PATH=/path/to/whisper-small

--- API keys (only required for API-based VLMs) ---
# DashScope API key for Qwen3-VL-Plus (used when model/vlm=qwen3vl_plus).
DASHSCOPE_API_KEY=sk-your-key-here
